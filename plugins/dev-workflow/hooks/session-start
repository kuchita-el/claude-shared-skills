#!/usr/bin/env bash
# SessionStart hook for dev-workflow plugin
# Injects completion-judgment.md principles into the session context.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

completion_judgment=$(cat "${PLUGIN_ROOT}/references/completion-judgment.md" 2>&1 || echo "Error reading completion-judgment.md")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

escaped=$(escape_for_json "$completion_judgment")
context="<COMPLETION_JUDGMENT_PRINCIPLES>\n${escaped}\n</COMPLETION_JUDGMENT_PRINCIPLES>"

# Cursor hooks expect additional_context (snake_case).
# Claude Code hooks expect hookSpecificOutput.additionalContext (nested).
# Copilot CLI and others expect additionalContext (top-level, SDK standard).
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "additional_context": "%s"\n}\n' "$context" | cat
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context" | cat
else
    printf '{\n  "additionalContext": "%s"\n}\n' "$context" | cat
fi

exit 0
