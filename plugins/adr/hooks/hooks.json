{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit:*)",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" adr-commit-gate"
          }
        ]
      }
    ]
  }
}
